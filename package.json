{
  "name": "hsnad-hey-streamer",
  "version": "1.0.0",
  "description": "HEY Streamer, Notice Alert Donation — All-in-one alert system untuk streamer Indonesia",
  "main": "src/main/main.js",
  "homepage": "./",
  "author": {
    "name": "noobiiefun",
    "url": "https://github.com/noobiiefun"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n REACT,ELECTRON -c cyan,yellow \"npm run dev:react\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:react": "cross-env BROWSER=none react-scripts start",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:check && npm run build:react && npm run build:exe",
    "build:react": "react-scripts build",
    "build:exe": "electron-builder --config electron-builder.yml --win --x64",
    "build:check": "node scripts/prebuild.js",
    "pack": "electron-builder --config electron-builder.yml --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version"]
  }
}
